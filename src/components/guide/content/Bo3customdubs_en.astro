  <ul class="bullet-list">
    <li>
      <a href="https://steamcommunity.com/sharedfiles/filedetails/?id=3373649394" target="_blank" rel="noopener">
        Mob of the Dead
      </a>
    </li>
    <li>
      <a href="https://steamcommunity.com/sharedfiles/filedetails/?id=3558354570" target="_blank" rel="noopener">
