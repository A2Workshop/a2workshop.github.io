---
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props;
const thumbnail = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
---

<button
  class="youtube-facade"
  type="button"
  data-youtube-id={videoId}
  data-youtube-title={title}
  aria-label={`Reproducir ${title}`}
>
  <img data-youtube-thumbnail data-src={thumbnail} alt="" width="480" height="360" decoding="async" />
  <span class="youtube-facade-play" aria-hidden="true">▶</span>
</button>

<script>
  document.addEventListener('astro:page-load', () => {
    const thumbnails = document.querySelectorAll<HTMLImageElement>('img[data-youtube-thumbnail][data-src]');
    const loadThumbnail = (thumbnail: HTMLImageElement) => {
      const src = thumbnail.dataset.src;
      if (!src) return;
      thumbnail.src = src;
      thumbnail.removeAttribute('data-src');
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          loadThumbnail(entry.target as HTMLImageElement);
          observer.unobserve(entry.target);
        });
      });
      thumbnails.forEach((thumbnail) => observer.observe(thumbnail));
    } else {
      thumbnails.forEach(loadThumbnail);
    }

    document.querySelectorAll<HTMLButtonElement>('.youtube-facade').forEach((button) => {
      // Prevent multiple listeners if astro:page-load fires again for the same element
      if (button.dataset.ytLoaded) return;
      button.dataset.ytLoaded = 'true';

      button.addEventListener('click', () => {
        const videoId = button.dataset.youtubeId;
        if (!videoId) return;

        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
        iframe.title = button.dataset.youtubeTitle ?? 'Video de YouTube';
        iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.referrerPolicy = 'strict-origin-when-cross-origin';
        button.replaceWith(iframe);
      }, { once: true });
    });
  });
</script>

<style is:global>
  .youtube-facade {
    position: relative;
    display: block;
    width: 100%;
    min-height: inherit;
    aspect-ratio: 16 / 9;
    padding: 0;
    overflow: hidden;
    border: 0;
    border-radius: 1rem;
    background: #05070a;
    cursor: pointer;
  }

  .youtube-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .youtube-facade:hover img,
  .youtube-facade:focus-visible img {
    filter: brightness(0.78);
    transform: scale(1.025);
  }

  .youtube-facade-play {
    position: absolute;
    top: 50%;
    left: 50%;
    display: grid;
    width: 4rem;
    height: 2.8rem;
    place-items: center;
    border-radius: 0.75rem;
    background: #f03;
    color: #fff;
    font-size: 1.35rem;
    line-height: 1;
    transform: translate(-50%, -50%);
  }

  .youtube-facade:focus-visible {
    outline: 3px solid var(--accent, #fff);
    outline-offset: 3px;
  }
</style>
