---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMenuItems, menuItems } from '../../data/nav';

const desktopSlides = [
  [3, 4],
  [5, 6],
  [1, 2],
];
const mobileSlides = [4, 3, 5, 6, 1, 2];
const menuItemsEn = getMenuItems('en');
const menuItemsEnByPath = new Map(
  menuItemsEn.map((item, index) => [item.href.replace(/^\/en(?=\/|$)/, ''), { ...item, index }]),
);
const mobileMenuText: Record<string, { es: string; en: string }> = {
  '/proyectos/blackopsiiilatino': { es: '(PC) COD: BOIII Espa\u00f1ol Latino', en: '(PC) COD: BOIII Latin American Spanish' },
  '/proyectos/blackopslatino': { es: '(PC) COD: BO Zombies Espa\u00f1ol Latino', en: '(PC) COD: BO Zombies Latin American Spanish' },
  '/proyectos/infinitewarfarelatino': { es: '(PC) COD: IW Espa\u00f1ol Latino', en: '(PC) COD: IW Latin American Spanish' },
  '/proyectos/modernwarfarerlatino': { es: '(PC) COD: MWR Espa\u00f1ol Latino', en: '(PC) COD: MWR Latin American Spanish' },
  '/proyectos/legobatman2latino': { es: '(PC) LB2 en Espa\u00f1ol Latino', en: '(PC) LB2 in Latin American Spanish' },
  '/traducciones/pq2espanol': { es: '(3DS) PQ2 Traducci\u00f3n al Espa\u00f1ol', en: '(3DS) PQ2 Spanish Translation' },
  '/traducciones/p4despanol': { es: '(PS4/PSV) P4D Traducci\u00f3n al Espa\u00f1ol', en: '(PS4/PSV) P4D Spanish Translation' },
  '/proyectos/bo3customdubs': { es: '(PC) COD: BOIII Custom Map Dubs', en: '(PC) COD: BOIII Custom Map Dubs' },
};
---

<BaseLayout
  title={'Persona Q2 - Traducci\u00f3n al Espa\u00f1ol'}
  description={'A2 Workshop - Persona Q2 en Espa\u00f1ol'}
  canonical="https://a2workshop.github.io/traducciones/pq2espanol"
  ogTitle="A2Workshop"
  ogImage="https://a2workshop.github.io/pq2/img/es_logo/webpreview.webp"
  themeColor="#f04e29"
  bodyClass="bg-black"
>
  <link slot="head" rel="stylesheet" href="/pq2/style.css" />

  <nav class="navbar" aria-label="Persona Q2">
    <a href="/" class="logo-link">
      <img src="/pq2/img/a2logo/logo_outline.webp" alt="A2Workshop" class="logo" width="6989" height="2955" decoding="async" />
    </a>
    <details class="pq2-dropdown">
      <summary
        class="nav-link pq2-dropdown-title"
        data-pq2-projects-title
        data-full-text="Proyectos | Persona Q2 Traducci&oacute;n al Espa&ntilde;ol"
        data-mobile-text="Proyectos"
        data-en-text="Projects | Persona Q2 Spanish Translation"
        data-en-mobile-text="Projects"
      >
        Proyectos | Persona Q2 Traducci&oacute;n al Espa&ntilde;ol
      </summary>
      <ul class="dropdown-menu">
        {menuItems.map((item, index) => {
          const englishItem = menuItemsEnByPath.get(item.href) ?? menuItemsEn[index];
          const shortText = mobileMenuText[item.href];
          return (
            <li data-en-order={englishItem?.index ?? index}>
              <a
                class="dropdown-item"
                href={item.href}
                data-pq2-menu-index={index}
                data-full-text={item.text}
                data-mobile-text={shortText?.es}
                data-en-text={englishItem?.text}
                data-en-mobile-text={shortText?.en}
                data-en-href={englishItem?.href}
              >
                {item.text}
              </a>
            </li>
          );
        })}
      </ul>
    </details>
    <a class="nav-link pq2-contact" href="/contacto" data-pq2-contact data-en-text="Contact" data-en-href="/en/contacto">Contacto</a>
  </nav>

  <div class="video-container">
    <iframe
      loading="lazy"
      src="https://www.youtube.com/embed/-RDqYkRxvig?autoplay=1&loop=1&mute=1&playlist=-RDqYkRxvig"
      frameborder="0"
      allow="autoplay"
      allowfullscreen
      title="fondo"
    ></iframe>
    <div class="video-overlay">
      <video autoplay loop muted playsinline class="logo" width="1972" height="1024" preload="metadata" poster="/pq2/img/es_logo/pq2_still.webp">
        <source src="/pq2/img/es_logo/pq2.webm" type="video/webm" />
      </video>
      <img src="/pq2/img/es_logo/pq2_still.webp" alt="Logo" class="fallback-image logo" width="1972" height="1024" style="display:none;" decoding="async" fetchpriority="high" />
      <a href="/traducciones/pq2espanol/descargar" id="downloadButton" class="pq2-button">Descargar</a>
    </div>
  </div>

  <div class="bg_section1">
    <div class="section2 pq2-trailer-section">
      <h2 class="font-title text-break">TR&Aacute;ILER</h2>
      <div class="trailer-video pq2-center">
        <iframe
          loading="lazy"
          width="560"
          height="315"
          src="https://www.youtube.com/embed/tKLf3WEvaNk?si=itraJQpi6VqBNd1r"
          title="YouTube video player"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
      <br />
    </div>
  </div>

  <div class="bg_section2 pq2-captures-section">
    <div class="section1">
      <h2 class="font-title pq2-captures-title text-break">CAPTURAS</h2>

      <div class="pq2-carousel pq2-desktop-gallery" data-carousel>
        <div class="carousel-inner">
          {desktopSlides.map((slide, slideIndex) => (
            <div class={`carousel-item${slideIndex === 0 ? ' active' : ''}`}>
              <div class="pq2-center">
                {slide.map((n) => (
                  <img src={`/pq2/img/screenshots/${n}.webp`} class="pq2-shot pq2-modal-trigger" alt={`prev${n}`} width="400" height="480" loading="lazy" decoding="async" />
                ))}
              </div>
            </div>
          ))}
        </div>
        <button class="carousel-control-prev" type="button" data-carousel-prev aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" aria-hidden="true">
            <g transform="scale(-1,1) translate(-24,0)"><path fill="currentColor" d="M8 5v14l11-7z"></path></g>
          </svg>
        </button>
        <button class="carousel-control-next" type="button" data-carousel-next aria-label="Siguiente">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M8 5v14l11-7z"></path>
          </svg>
        </button>
      </div>

      <div class="pq2-carousel pq2-mobile-gallery" data-carousel>
        <div class="carousel-inner">
          {mobileSlides.map((n, slideIndex) => (
            <div class={`carousel-item${slideIndex === 0 ? ' active' : ''}`}>
              <div class="pq2-center">
                <img src={`/pq2/img/screenshots/${n}.webp`} class="pq2-shot pq2-modal-trigger" alt={`prev${slideIndex}`} width="400" height="480" loading="lazy" decoding="async" />
              </div>
            </div>
          ))}
        </div>
        <button class="carousel-control-prev" type="button" data-carousel-prev aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" aria-hidden="true">
            <g transform="scale(-1,1) translate(-24,0)"><path fill="currentColor" d="M8 5v14l11-7z"></path></g>
          </svg>
        </button>
        <button class="carousel-control-next" type="button" data-carousel-next aria-label="Siguiente">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M8 5v14l11-7z"></path>
          </svg>
        </button>
      </div>
    </div>
    <h1 class="h1-cust text-break">Persona Q2 traducci&oacute;n al espa&ntilde;ol</h1>
  </div>

  <dialog id="imageModal" class="pq2-modal">
    <button id="modalClose" class="pq2-modal-close" aria-label="Cerrar">&times;</button>
    <button id="prevImage" class="pq2-modal-arrow pq2-modal-prev" aria-label="Anterior">&#8249;</button>
    <img id="modalImage" alt="captura ampliada" decoding="async" />
    <button id="nextImage" class="pq2-modal-arrow pq2-modal-next" aria-label="Siguiente">&#8250;</button>
  </dialog>

  <footer class="pq2-footer pq2-footer-mobile">
    <a class="logo-link" href="/">
      <img src="/pq2/img/a2logo/logo_outline.webp" alt="Logo" class="pq2-footer-logo" width="6989" height="2955" loading="lazy" decoding="async" />
    </a>
    <p>Este proyecto no est&aacute; afiliado con ATLUS o SEGA. Todos los derechos reservados por sus respectivos propietarios.</p>
  </footer>
  <footer class="pq2-footer pq2-footer-desktop">
    <div class="pq2-footer-grid">
      <a class="logo-link" href="/">
        <img src="/pq2/img/a2logo/logo_outline.webp" alt="Logo" class="pq2-footer-logo" width="6989" height="2955" loading="lazy" decoding="async" />
      </a>
      <div></div>
      <p>Este proyecto no est&aacute; afiliado con ATLUS o SEGA. Todos los derechos reservados por sus respectivos propietarios.</p>
    </div>
  </footer>

  <script>
    import '../../scripts/pq2-page.ts';
  </script>
  <script is:inline>
    (() => {
      const media = window.matchMedia('(max-width: 990px)');
      const dropdown = document.querySelector('.pq2-dropdown');
      const getLang = () => new URLSearchParams(window.location.search).get('lang') === 'en' ? 'en' : 'es';
      const syncLabels = () => {
        const lang = getLang();
        document.querySelectorAll('.pq2-dropdown-title, .pq2-dropdown .dropdown-item').forEach((item) => {
          const full = lang === 'en' ? item.dataset.enText : item.dataset.fullText;
          const short = lang === 'en' ? item.dataset.enMobileText : item.dataset.mobileText;
          item.textContent = media.matches && short ? short : full || item.textContent;
        });
      };
      const closeDropdown = (event) => {
        if (!dropdown?.open) return;
        if (event.target instanceof Node && dropdown.contains(event.target)) return;
        dropdown.open = false;
      };
      media.addEventListener?.('change', syncLabels);
      document.addEventListener('pointerdown', closeDropdown);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && dropdown?.open) dropdown.open = false;
      });
      document.addEventListener('DOMContentLoaded', () => {
        syncLabels();
        setTimeout(syncLabels, 0);
      });
      window.addEventListener('load', syncLabels);
      syncLabels();
    })();
  </script>

  <style>
    .bg-black {
      background-color: #000;
    }
    .pq2-center {
      display: flex;
      justify-content: center;
    }
    .text-break {
      overflow-wrap: break-word;
      word-break: break-word;
    }
    .pq2-trailer-section {
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
    }
    .pq2-captures-section {
      padding-bottom: 3rem;
    }
    .pq2-captures-title {
      padding-top: 1rem;
    }
    .pq2-button {
      display: inline-block;
      margin-top: 0.5rem;
      padding: 0.375rem 0.75rem;
      border: 5px solid #f04e29;
      border-radius: 0;
      background: #f04e29;
      color: #fff;
      line-height: 1.5;
      text-decoration: none;
    }
    .pq2-button:hover {
      background: #9e341c;
      border-color: #9e341c;
      color: #fff;
    }
    .navbar {
      box-shadow: none;
      box-sizing: border-box;
      left: 0;
      max-width: 100%;
    }
    .navbar a,
    .nav-link {
      color: #fff;
      text-decoration: none;
    }
    .logo-link {
      display: inline-flex;
      align-items: center;
    }
    .pq2-dropdown {
      position: relative;
      min-width: 0;
    }
    .pq2-dropdown-title {
      cursor: pointer;
      list-style: none;
      max-width: 100%;
      overflow-wrap: anywhere;
    }
    .pq2-dropdown-title::-webkit-details-marker {
      display: none;
    }
    .pq2-dropdown .dropdown-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      min-width: 320px;
      padding: 0.5rem 0;
      margin: 0;
      list-style: none;
      background: #000;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
      z-index: 20;
    }
    .pq2-dropdown[open] .dropdown-menu {
      display: block;
    }
    .dropdown-item {
      display: block;
      padding: 0.4rem 1rem;
      text-decoration: none;
    }
    .pq2-contact {
      margin-left: 20px;
    }
    .pq2-carousel {
      position: relative;
      width: 100%;
    }
    .pq2-mobile-gallery {
      display: none;
    }
    .carousel-item {
      display: none;
    }
    .carousel-item.active {
      display: block;
    }
    .pq2-shot {
      cursor: pointer;
    }
    .carousel-control-prev,
    .carousel-control-next {
      position: absolute;
      top: 0;
      bottom: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 15%;
      padding: 0;
      border: 0;
      background: transparent;
      color: #fff;
      opacity: 0.5;
      cursor: pointer;
      z-index: 2;
    }
    .carousel-control-prev:hover,
    .carousel-control-next:hover {
      opacity: 0.9;
    }
    .carousel-control-prev {
      left: 0;
    }
    .carousel-control-next {
      right: 0;
    }
    .pq2-modal {
      width: 100vw;
      max-width: 100vw;
      height: 100vh;
      max-height: 100vh;
      border: none;
      padding: 0;
      background: rgba(0, 0, 0, 0.9);
    }
    .pq2-modal::backdrop {
      background: rgba(0, 0, 0, 0.8);
    }
    .pq2-modal img,
    .pq2-modal #modalImage {
      width: auto;
      height: auto;
      max-width: 92vw;
      max-height: 90vh;
      object-fit: contain;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) !important;
    }
    @media (min-width: 990px) {
      .pq2-modal img,
      .pq2-modal #modalImage {
        width: min(96vw, 80vh);
        height: auto;
        max-width: 96vw;
        max-height: 96vh;
      }
    }
    .pq2-modal-close,
    .pq2-modal-arrow {
      position: absolute;
      background: none;
      border: none;
      color: #ffffff9a;
      cursor: pointer;
      z-index: 2;
    }
    .pq2-modal-close {
      top: 1rem;
      right: 1.5rem;
      font-size: 2.5rem;
      line-height: 1;
    }
    .pq2-modal-arrow {
      top: 50%;
      transform: translateY(-50%);
      font-size: 4rem;
      line-height: 1;
      padding: 0 1rem;
    }
    .pq2-modal-prev {
      left: 0.5rem;
    }
    .pq2-modal-next {
      right: 0.5rem;
    }
    .pq2-footer {
      margin-top: 3rem;
      padding-bottom: 3rem;
    }
    .pq2-footer-logo {
      width: 200px;
      height: auto;
    }
    .pq2-footer-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: min(100% - 24px, 1320px);
      margin: 0 auto;
      align-items: start;
    }
    .pq2-footer p {
      margin: 0;
      color: #fff;
      text-align: center;
      line-height: 1.5;
    }
    .pq2-footer-mobile {
      display: none;
      width: min(100% - 24px, 1320px);
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }
    .pq2-footer-mobile p {
      max-width: 440px;
      margin: 1rem auto 0;
    }
    @media (max-width: 990px) {
      .pq2-desktop-gallery,
      .pq2-footer-desktop {
        display: none;
      }
      .pq2-mobile-gallery {
        display: block;
      }
      .pq2-footer-mobile {
        display: block;
      }
      .pq2-contact {
        margin-left: 8px;
      }
      .pq2-dropdown .dropdown-menu {
        position: fixed;
        top: 70px;
        left: 12px;
        right: 12px;
        min-width: 0;
        max-width: none;
        width: auto;
        max-height: calc(100vh - 88px);
        overflow-y: auto;
      }
    }
  </style>
</BaseLayout>
