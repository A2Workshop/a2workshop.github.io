---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import DownloadIcon from '../../../components/icons/DownloadIcon.astro';
import MobileDrawer from '../../../components/MobileDrawer.astro';

const creadores = [
  {
    img: '/assets/img/Profile/Artur16211.webp',
    alt: 'Artur16211',
    name: 'Artur16211',
    id: 'socialArtur',
    socials: [
      { icon: 'logos:youtube-icon', href: 'https://www.youtube.com/@artur16211', label: 'Artur16211', yt: true },
      { icon: 'skill-icons:discord', label: 'artur16211' },
    ],
  },
  {
    img: '/assets/img/Profile/HxCannon.webp',
    alt: 'HxCannon',
    name: 'HxCannon',
    id: 'socialHxCannon',
    socials: [
      { icon: 'logos:youtube-icon', href: 'https://www.youtube.com/@hxcannon', label: 'HxCannon', yt: true },
      { icon: 'skill-icons:discord', label: 'hxcannon' },
    ],
  },
  {
    img: '/assets/img/Profile/Manuovi_07.webp',
    alt: 'Manuovi_07',
    name: 'Manuovi_07',
    id: 'socialManuovi',
    socials: [{ icon: 'skill-icons:discord', label: 'manuovi_07' }],
  },
];

const creditos = [
  { name: 'TGE', href: 'https://github.com/tge-was-taken/Atlus-Script-Tools', text: 'AtlusScriptTools' },
  { name: 'ShrineFox', href: 'https://shrinefox.com/browse?post=pq2talkanimfix', text: 'Talk Animation Fix y documentación.' },
  { name: 'DeathChaos25', href: 'https://github.com/DeathChaos25/PQ_Patches', text: 'PQ Patches', extra: { href: 'https://github.com/DeathChaos25/PQ2PersonaNameTBL', text: 'PQ2PersonaNameTBL' } },
  { name: 'Melonman19', href: 'https://github.com/Meloman19/PersonaEditor', text: 'Persona Editor' },
  { name: 'Pioziomgames', href: 'https://gamebanana.com/tools/8939', text: 'Bam Editor' },
  { name: 'hadashisora', href: 'https://github.com/hadashisora/NintyFont', text: 'NintyFont' },
  { name: 'ObsidianX', href: 'https://github.com/ObsidianX/3dstools', text: '3dstools' },
  { name: 'lraty-li', href: 'https://github.com/lraty-li/Persona-Modding', text: 'Búsqueda de texto en code.bin.' },
  { name: 'FanTranslatorsInternational', href: 'https://github.com/FanTranslatorsInternational/Kuriimu2', text: 'Kuriimu2' },
  { name: 'MapStudioProject', href: 'https://github.com/MapStudioProject/CTR-Studio', text: 'CTR Studio' },
];

---

<BaseLayout
  title="PQ2 en Español - Descargar"
  description="Guía de instalación del parche de traducción al Español de Persona Q2: New Cinema Labyrinth."
  canonical="https://a2workshop.github.io/traducciones/pq2espanol/descargar"
  ogTitle="A2Workshop"
  ogImage="https://a2workshop.github.io/pq2/img/es_logo/webpreview.webp"
  themeColor="#141414"
  bodyClass="bg_bg"
  bodyStyle="background-color: #141414;"
  iconify
>
  <link slot="head" rel="stylesheet" href="/pq2/guide/style.css" />

  <Navbar
    activeKey="default"
    boldProyecto
    fullLogoSrc="/pq2/img/a2logo/full_logo.webp"
    mobileLogoSrc="/pq2/img/a2logo/logo.webp"
  />

  <style is:global>
    #navbar-container .a2-navbar {
      background: #141414 !important;
      -webkit-backdrop-filter: none !important;
      backdrop-filter: none !important;
    }
  </style>

  <div class="mx-auto flex max-w-[1140px] flex-wrap px-3">
    <div class="w-full px-3 min-[992px]:w-3/4">
      <div class="mt-2 rounded-[15px] bg_container p-6 video-overlay">
        <a href="/traducciones/pq2espanol">
          <video autoplay loop muted playsinline class="logo" width="1972" height="1024" preload="metadata" poster="/pq2/img/es_logo/pq2_still-1350.webp">
            <source src="/pq2/img/es_logo/pq2-1350.webm" type="video/webm" />
          </video>
          <img src="/pq2/img/es_logo/pq2_still-1350.webp" alt="Logo" class="fallback-image logo" width="1972" height="1024" style="display: none;" decoding="async" fetchpriority="high" />
        </a>
        <h1 class="text-center text-[1.75rem]">
          Parche de traducción al Español de Persona Q<span class="orange-text">2</span>: New Cinema Labyrinth
        </h1>
      </div>

      <div class="mt-2 rounded-[15px] bg_container p-6">
        <div class="mt-4 grid grid-cols-3 hide-changeguide-mobile">
          <button data-guide="instalacion" class="btn btn-guide w-full">Instalación</button>
          <button data-guide="extras" class="btn btn-guide w-full disabled-guide">Extras</button>
          <button data-guide="faq" class="btn btn-guide w-full disabled-guide">FAQ</button>
        </div>
        <div class="flex flex-col hide-changeguide-desktop">
          <button data-guide="instalacion" class="btn btn-guide-mobile mb-2 w-full">Instalación</button>
          <button data-guide="extras" class="btn btn-guide-mobile mb-2 w-full disabled-guide">Extras</button>
          <button data-guide="faq" class="btn btn-guide-mobile w-full disabled-guide">FAQ</button>
        </div>

        <div id="guide-content">
          <section id="guide-instalacion">
            <h2 class="title3 break-words">Guía de Instalación</h2>
            <section class="mt-6">
              <h2 class="title2 break-words">Requisitos</h2>
              <p class="mb-4 text-xl">Para jugar a Persona Q<span class="orange-text">2</span> en español necesitarás:</p>
              <ul class="ml-6 list-disc text-xl">
                <li>Una consola <span class="red-text">2</span>DS/<span class="red-text">3</span>DS con un CFW como Luma3DS, o un emulador instalado de <span class="ct-text">3</span>DS en tu dispositivo.</li>
                <li>Una copia del juego <b>región USA</b>.</li>
              </ul>
              <hr />
              <h2 class="title2 break-words">DESCARGAS</h2>
              <h2 class="title1">Formato Parche (xdelta):</h2>
              <a href="https://www.mediafire.com/file/m8gqcxkosv595ra/PQ2SpanishTranslation1.3.3.xdelta/file" target="_blank" class="btn btn-primary1 mt-2 border-[5px]">Formato Parche <DownloadIcon /></a>
              <br />
              <h2 class="title1">Formato LayerFS (mod.cpk):</h2>
              <a href="https://www.mediafire.com/file/vka1f4eie3nm5i6/mod.cpk/file" target="_blank" class="btn btn-primary2 mt-2 border-[5px]">Formato LayerFS <DownloadIcon /></a>
              <hr />
              <br>
              <h2 class="title2 break-words">Método de Instalación</h2>
              <div class="border-explanation p-4">
                <p class="mb-4 text-xl font-bold blue-text">Parcheo de ROM:</p>
                <p class="mb-4 text-base">
                  Este método consiste en aplicar un parche <b>xdelta</b> a un archivo <b>.cia</b>
                  <b class="break-words">desencriptado</b> y <b>extraído de tu cartucho</b>, generando un nuevo
                  <b>.cia</b> con la traducción aplicada.<br />(<b>Solo copias físicas</b>)
                </p>
                <p class="mb-4 text-xl font-bold pink-text">LayerFS:</p>
                <p class="mb-4 text-base">
                  Este método permite reemplazar archivos del juego mediante <b>LayerFS</b>, sin modificar directamente la ROM.
                </p>
              </div>
              <br />
              <div class="my-4 text-center">
                <button class="btn btn-design btn-patch mx-2" data-method="parcheo" id="patchrom_btn">Parcheo de ROM</button>
                <br class="min-[769px]:hidden" /><br class="min-[769px]:hidden" />
                <button class="btn btn-design btn-layer mx-2" data-method="layerfs" id="layerfs_btn">LayerFS</button>
              </div>
              <div id="method-content" class="p-4 text-center text-xl">
                <p>Selecciona un método de instalación para continuar.</p>

                <div id="method-parcheo" class="hidden text-base">
                  <h2 class="text-center">Parcheo de ROM</h2>
                  <div class="text-left font-bold">Paso 1:</div>
                  <p class="text-left">Descarga el parche de traducción en formato <a class="blue-text no-underline">Parche (xdelta)</a>.</p>
                  <hr />
                  <div class="text-left font-bold">Paso 2:</div>
                  <p class="text-left">Con la consola apagada, mantén presionado el botón <code class="console-btn">START</code> y enciéndela para acceder al menú de <b>GodMode9</b>.</p>
                  <p class="text-left">En este menú, selecciona el cartucho de Persona Q<a class="orange-text no-underline">2</a> "<b>GAMECART (CTR9002F0C2)</b>" y presiona <code class="console-btn btn-a">A</code>.</p>
                  <img src="/pq2/img/tutorial_patch/gm9/root_1.webp" alt="Paso 1" class="tutorial-img tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 5 / 3; width: 100%; object-fit: contain;" />
                  <hr />
                  <div class="mt-4 text-left font-bold">Paso 3:</div>
                  <p class="mb-4 text-left">Selecciona el formato <b class="break-words">00040000001D7100_v00.trim.3ds</b> y presiona <code class="console-btn btn-a">A</code>.</p>
                  <img src="/pq2/img/tutorial_patch/gm9/c_2.webp" alt="Paso 2" class="tutorial-img tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 5 / 3; width: 100%; object-fit: contain;" />
                  <hr />
                  <div class="mt-4 text-left font-bold">Paso 4:</div>
                  <p class="mb-4 text-left">Selecciona <b>NCSD image options...</b></p>
                  <img src="/pq2/img/tutorial_patch/gm9/top_1.webp" alt="Paso 3" class="tutorial-img tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 5 / 6; width: 100%; object-fit: contain;" />
                  <hr />
                  <div class="mt-4 text-left font-bold">Paso 5:</div>
                  <p class="mb-4 text-left">Selecciona <b>Build CIA from file</b>.</p>
                  <img src="/pq2/img/tutorial_patch/gm9/top_2.webp" alt="Paso 4" class="tutorial-img tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 5 / 6; width: 100%; object-fit: contain;" />
                  <hr />
                  <div class="mt-4 text-left font-bold">Paso 6:</div>
                  <p class="mb-4 text-left">Espera a que el proceso termine y presiona <code class="console-btn btn-a">A</code> para continuar.</p>
                  <img src="/pq2/img/tutorial_patch/gm9/top_3.webp" alt="Paso 5" class="tutorial-img tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 5 / 6; width: 100%; object-fit: contain;" />
                  <hr />
                  <div class="mt-4 text-left font-bold">Paso 7:</div>
                  <p class="mb-4 text-left">Conecta tu tarjeta SD a tu computadora y en <b>gm9/out</b> copia el archivo <b class="break-words">00040000001D7100_v00.trim.standard.cia</b>.</p>
                  <img src="/pq2/img/tutorial_patch/SD.webp" alt="Paso 6" class="tutorial-img tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 54 / 19; width: 100%; object-fit: contain;" />
                  <div class="mt-4 text-left font-bold">Paso 8:</div>
                  <p class="mb-4 text-left">Descarga algún programa para aplicar parches <b>xdelta</b> como <a href="https://www.romhacking.net/utilities/704/" target="_blank" class="no-underline link-color">Delta Patcher</a> para aplicar el <a class="blue-text no-underline">parche</a> ya descargado.</p>
                  <hr />
                  <div class="mt-4 text-left font-bold">Paso 9:</div>
                  <p class="mb-4 text-left">Abre el programa, selecciona el archivo <b class="break-words">00040000001D7100_v00.trim.standard.cia</b> como <b>Original file</b> y el parche de traducción como <b>XDelta patch</b>.</p>
                  <img src="/pq2/img/tutorial_patch/Delta.webp" alt="Paso 8" class="tutorial-img tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 265 / 249; width: 100%; object-fit: contain;" />
                  <hr />
                  <div class="mt-4 text-left font-bold">Paso 10:</div>
                  <p class="mb-4 text-left">Aplica el parche y se reemplazará tu archivo .cia original. Esta será tu ROM con la traducción aplicada, lista para instalar en tu consola o emulador.</p>
                </div>

                <div id="method-layerfs" class="hidden text-base">
                  <h2 class="text-center">LayerFS</h2>
                  <div class="text-left font-bold">Paso 1:</div>
                  <p class="text-left">Descarga el parche de traducción en formato <a class="pink-text no-underline">LayerFS (mod.cpk)</a>.</p>
                  <hr />
                  <div class="text-left font-bold">Paso 2:</div>
                  <p class="text-left">Descarga los <a class="no-underline text-white" data-guide="extras" data-scroll="pqpatches" href="#"><b>PQ Patches</b></a> (<code>code.bin</code> y <code>exheader.bin</code>) para cargar la traducción desde el <a class="pink-text no-underline">mod.cpk</a> en la sección <a class="no-underline link-color" data-guide="extras" data-scroll="pqpatches" href="#">Extras</a>.</p>
                  <div class="my-4 text-center">
                    <div class="grid grid-cols-1 gap-y-4 min-[992px]:grid-cols-3 min-[992px]:gap-y-0 min-[992px]:gap-x-4">
                      <button class="btn btn-console btn-design w-full" data-device="console">Consola (<span class="red-text">2</span>DS/<span class="red-text">3</span>DS)</button>
                      <button class="btn btn-android btn-design w-full" data-device="android">Android</button>
                      <button class="btn btn-pc btn-design w-full" data-device="pc">PC</button>
                    </div>
                  </div>
                  <div id="content-device" class="p-4">
                    <p>Selecciona un dispositivo para continuar.</p>

                    <div id="device-console" class="hidden">
                      <hr />
                      <div class="text-left font-bold">Paso 3:</div>
                      <p class="text-left">Con la consola apagada, mantén presionado el botón <code class="console-btn">SELECT</code> y enciéndela para acceder al menú de Luma3DS.</p>
                      <p class="text-left">En este menú, activa la opción <strong>"Enable game patching"</strong> y luego presiona <strong>"Save and exit"</strong>.</p>
                      <img src="/pq2/img/tutorial_cpk/console/1.webp" alt="Paso 3" class="tutorial-img" loading="lazy" decoding="async" style="aspect-ratio: 100 / 61; width: 100%; object-fit: contain;" />
                      <hr />
                      <div class="mt-4 text-left font-bold">Paso 4:</div>
                      <p class="text-left">Extrae la tarjeta SD de tu consola, insértala en tu computadora y copia los siguientes archivos a la carpeta <code>luma/titles/00040000001D7100</code>:</p>
                      <ul class="ml-6 list-disc text-left">
                        <li>En la raíz de <code>00040000001D7100</code>: coloca <code>code.bin</code> y <code>exheader.bin</code>.</li>
                        <li>Dentro de una subcarpeta llamada <code>romfs</code>: coloca <code>mod.cpk</code>.</li>
                      </ul>
                      <img src="/pq2/img/tutorial_cpk/console/2.webp" alt="Paso 4" class="tutorial-img" loading="lazy" decoding="async" style="aspect-ratio: 233 / 84; width: 100%; object-fit: contain;" /><br /><br />
                      <img src="/pq2/img/tutorial_cpk/console/3.webp" alt="Paso 4" class="tutorial-img" loading="lazy" decoding="async" style="aspect-ratio: 233 / 54; width: 100%; object-fit: contain;" />
                    </div>

                    <div id="device-android" class="hidden">
                      <hr />
                      <div class="text-left font-bold">Paso 3:</div>
                      <p class="text-left">Abre el explorador de archivos de tu dispositivo y ubica la carpeta de tu emulador de <span class="ct-text">3</span>DS.</p>
                      <img src="/pq2/img/tutorial_cpk/Android/1.webp" alt="Paso 3" class="tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 524 / 599; width: 100%; object-fit: contain;" />
                      <hr />
                      <div class="mt-4 text-left font-bold">Paso 4:</div>
                      <p class="text-left">Una vez allí, navega a <code class="break-words">load/mods/00040000001D7100</code>. Si la carpeta no existe, créala manualmente.</p>
                      <img src="/pq2/img/tutorial_cpk/Android/2.webp" alt="Paso 4" class="tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 527 / 375; width: 100%; object-fit: contain;" /><br /><br />
                      <img src="/pq2/img/tutorial_cpk/Android/3.webp" alt="Paso 4" class="tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 522 / 159; width: 100%; object-fit: contain;" />
                      <hr />
                      <div class="mt-4 text-left font-bold">Paso 5:</div>
                      <p class="text-left">Dentro de <code class="break-words">00040000001D7100</code>, crea dos nuevas carpetas llamadas <code>romfs</code> y <code>exefs</code>.</p>
                      <img src="/pq2/img/tutorial_cpk/Android/4.webp" alt="Paso 5" class="tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 531 / 271; width: 100%; object-fit: contain;" />
                      <hr />
                      <div class="mt-4 text-left font-bold">Paso 6:</div>
                      <p class="text-left">Coloca los siguientes archivos en las carpetas correspondientes:</p>
                      <ul class="ml-6 list-disc text-left">
                        <li><b>exefs</b>: Pega el archivo <code>code.bin</code>.</li>
                        <li><b>romfs</b>: Pega el archivo <code>mod.cpk</code>.</li>
                        <li>En la raíz de <code>/00040000001D7100</code>: Pega el archivo <code>exheader.bin</code>.</li>
                      </ul>
                      <img src="/pq2/img/tutorial_cpk/Android/5.webp" alt="Paso 6" class="tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 531 / 177; width: 100%; object-fit: contain;" /><br /><br />
                      <img src="/pq2/img/tutorial_cpk/Android/6.webp" alt="Paso 6" class="tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 525 / 168; width: 100%; object-fit: contain;" /><br /><br />
                      <img src="/pq2/img/tutorial_cpk/Android/7.webp" alt="Paso 6" class="tutorial-img-android" loading="lazy" decoding="async" style="aspect-ratio: 531 / 370; width: 100%; object-fit: contain;" />
                    </div>

                    <div id="device-pc" class="hidden">
                      <hr />
                      <div class="text-left font-bold">Paso 3:</div>
                      <p class="text-left">Abre tu emulador de <span class="ct-text">3</span>DS y haz clic derecho en el juego <strong>Persona Q2</strong>. Luego, abre el submenú <strong>"Open"</strong> y selecciona <strong>"Mods Location"</strong>.</p>
                      <img src="/pq2/img/tutorial_cpk/pc/2.webp" alt="Paso 3" class="tutorial-img" loading="lazy" decoding="async" style="aspect-ratio: 811 / 425; width: 100%; object-fit: contain;" />
                      <hr />
                      <div class="mt-4 text-left font-bold">Paso 4:</div>
                      <p class="text-left">En la carpeta que se abrió, coloca los siguientes archivos en sus respectivas ubicaciones:</p>
                      <ul class="ml-6 list-disc text-left">
                        <li><b>exefs</b>: Pega el archivo <code>code.bin</code>.</li>
                        <li><b>romfs</b>: Pega el archivo <code>mod.cpk</code>.</li>
                        <li>En la raíz de la carpeta: Pega el archivo <code>exheader.bin</code>.</li>
                      </ul>
                      <img src="/pq2/img/tutorial_cpk/pc/3.webp" alt="Paso 4" class="tutorial-img" loading="lazy" decoding="async" style="aspect-ratio: 399 / 173; width: 100%; object-fit: contain;" />
                    </div>
                  </div>
                </div>
              </div>
            </section>
          </section>

          <section id="guide-extras" class="hidden">
            <h2 class="title3">Extras</h2>
            <h4 class="mb-4 font-bold uppercase">Índice</h4>
            <div class="index-design text-center">
              <a class="nav-link mt-2 text-2xl" data-scroll="texturas-hd" href="#">Texturas/Interfaz HD</a>
              <hr />
              <a class="nav-link mb-2 text-2xl" data-scroll="pqpatches" href="#">PQ Patches (Nombres Canónicos y Mod CPK)</a>
            </div>
            <section class="mt-6" id="texturas-hd">
              <h2 class="title2 break-words">Texturas/Interfaz HD</h2>
              <p class="text-xl">Paquete de texturas HD creado por <b>HxCannon</b>.</p>
              <ul class="ml-6 list-disc text-xl">
                <li>Para que las texturas HD se muestren correctamente, se recomienda configurar la resolución interna del emulador en al menos <b>3x</b>.</li>
              </ul>
              <br class="max-[1200px]:block hidden" />
              <div class="accordion" data-accordion="accordionImages">
                <div class="accordion-item text-white">
                  <h2 class="accordion-header">
                    <button class="accordion-button text-white" type="button" data-collapse-target="#collapseOne" data-collapse-group="accordionImages">Batalla</button>
                  </h2>
                  <div id="collapseOne" class="collapsible is-open">
                    <div class="image-comparator" id="comparator-1">
                      <div class="image-container">
                        <img src="/pq2/img/comparison_hd/hd/battle-1280.webp" class="image-before" alt="HD batalla" width="1280" height="768" loading="lazy" decoding="async" />
                        <img src="/pq2/img/comparison_hd/sd/battle.webp" class="image-after" alt="SD batalla" loading="lazy" decoding="async" />
                      </div>
                      <div class="slider"></div>
                    </div>
                  </div>
                </div>
                <div class="accordion-item text-white">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed text-white" type="button" data-collapse-target="#collapseTwo" data-collapse-group="accordionImages">Taquilla</button>
                  </h2>
                  <div id="collapseTwo" class="collapsible">
                    <div class="image-comparator" id="comparator-2">
                      <div class="image-container">
                        <img src="/pq2/img/comparison_hd/hd/taquilla-1280.webp" class="image-before" alt="HD taquilla" width="1280" height="768" loading="lazy" decoding="async" />
                        <img src="/pq2/img/comparison_hd/sd/taquilla.webp" class="image-after" alt="SD taquilla" loading="lazy" decoding="async" />
                      </div>
                      <div class="slider"></div>
                    </div>
                  </div>
                </div>
                <div class="accordion-item text-white">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed text-white" type="button" data-collapse-target="#collapseThree" data-collapse-group="accordionImages">Habitación Terciopelo</button>
                  </h2>
                  <div id="collapseThree" class="collapsible">
                    <div class="image-comparator" id="comparator-3">
                      <div class="image-container">
                        <img src="/pq2/img/comparison_hd/hd/fusion-1600.webp" class="image-before" alt="HD fusión" width="1600" height="534" loading="lazy" decoding="async" />
                        <img src="/pq2/img/comparison_hd/sd/fusion.webp" class="image-after" alt="SD fusión" loading="lazy" decoding="async" />
                      </div>
                      <div class="slider"></div>
                    </div>
                  </div>
                </div>
              </div>
              <br />
              <h2 class="title mt-2">Instalación</h2>
              <br />
              <p class="text-xl"><b>Opción 1</b>: En tu emulador de <span class="ct-text">3</span>DS con el juego agregado o instalado, da clic derecho y selecciona <b>Open</b>, <b>Custom Texture Location</b> y extrae el contenido del archivo .zip a la carpeta que se abrirá.</p>
              <br />
              <p class="text-xl"><b>Opción 2</b>: En la carpeta de tu emulador de <span class="ct-text">3</span>DS, entra a <code>load/textures/00040000001D7100</code> y pega el contenido del archivo .zip.</p>
              <br />
              <img src="/pq2/img/tutorial_textures/1.webp" class="tutorial-img tutorial-img-texturas" alt="Paso 1" loading="lazy" decoding="async" style="aspect-ratio: 823 / 431; width: 100%; object-fit: contain;" />
              <br /><br />
              <p class="text-xl">Después de extraer el contenido, regresa al emulador y en el menú de configuración activa la opción <b>Use Custom Textures</b>.</p>
              <br />
              <img src="/pq2/img/tutorial_textures/2.webp" class="tutorial-img tutorial-img-texturas" alt="Paso 2" loading="lazy" decoding="async" style="aspect-ratio: 780 / 471; width: 100%; object-fit: contain;" />
              <br /><br />
              <h2 class="title">Enlace:</h2>
              <a href="https://ouo.io/xNfAmx" target="_blank" class="btn btn-primary mt-2 border-[5px]">Texturas HD <DownloadIcon /></a>
            </section>
            <hr />
            <section class="mt-6" id="alt-layout">
              <h2 class="title2 text-center text-3xl">Add-on: A/B - X/Y</h2>
              <p class="text-xl">Intercambia <b>A/B</b> y <b>X/Y</b>, requiere las <b>Texturas HD</b>.</p>
              <br class="max-[1200px]:block hidden" />
              <div class="accordion" data-accordion="accordionImagesAlt">
                <div class="accordion-item text-white">
                  <h2 class="accordion-header">
                    <button class="accordion-button accordion-button-addon text-white" type="button" data-collapse-target="#collapseFour" data-collapse-group="accordionImagesAlt">Batalla</button>
                  </h2>
                  <div id="collapseFour" class="collapsible is-open">
                    <img src="/pq2/img/addon/batalla-1280.webp" alt="addon batalla" class="addon-img" width="1280" height="768" loading="lazy" decoding="async" style="aspect-ratio: 5 / 3; width: 100%; object-fit: contain;" />
                  </div>
                </div>
              </div>
              <br />
              <a href="https://www.mediafire.com/file/34zgd88q2v4ekmf/PersonaQ2ES_Addon_AB-XY_Layout.7z/file" target="_blank" class="btn btn-primary mt-2 border-[5px]">ADD-ON: A/B - X/Y<DownloadIcon /></a>
            </section>
            <hr />
            <section class="mt-6" id="pqpatches">
              <h2 class="title2">PQ Patches</h2>
              <p class="text-xl">Estos parches creados por <a href="https://github.com/DeathChaos25" target="_blank" class="no-underline link-color">DeathChaos25</a>, permiten mostrar los <span class="text-secondary">nombres "canónicos"</span> de los protagonistas y habilitar el <span class="text-secondary">soporte para mods</span> cargando un archivo <code>mod.cpk</code> a través de <a class="pink-text no-underline">LayerFS</a>.<br /><br />Estos los puedes instalar siguiendo las instrucciones en su <a class="no-underline link-color" href="https://github.com/DeathChaos25/PQ_Patches" target="_blank">repositorio de GitHub</a> o descargando los archivos <code>code.bin</code> y <code>exheader.bin</code> ya <b>pre-parcheados al español</b> en los siguientes enlaces.</p>
              <h2 class="title">Descargas:</h2>
              <a href="https://www.mediafire.com/folder/92r7usmlwc0xy/ModCPK" class="btn btn-primary mt-2 border-[5px]" target="_blank">Versión <b>soporte MOD.CPK</b> <DownloadIcon /></a>
              <br />
              <a href="https://www.mediafire.com/folder/pbta1djdhcxl2/ModCPK_CanonNames" class="btn btn-primary mt-2 border-[5px]" target="_blank">Versión <b>soporte MOD.CPK</b> y <b>Nombres Canónicos</b> <DownloadIcon /></a>
              <br />
              <p class="border-explanation2 p-4 text-base">Si instalaste la traducción con el método de <a class="blue-text no-underline">Parcheo de ROM</a> y quieres utilizar los <b class="text-secondary">nombres "canónicos"</b>, deberás colocar un <b>mod.cpk vacío</b> en la carpeta <code>luma/titles/00040000001D7100/romfs/</code> de tu <b class="red-text">consola</b> o en <code>load/mods/00040000001D7100/romfs/</code> de tu <b class="ct-text">emulador</b>.</p>
              <a href="https://www.mediafire.com/file/680rr12mc4rr19v/mod.cpk/file" class="btn btn-primary3 mt-2 border-[5px]" target="_blank"><b>MOD.CPK vacío</b> <DownloadIcon /></a>
            </section>
          </section>

          <section id="guide-faq" class="hidden">
            <h2 class="title3 break-words">FAQ <br />(Preguntas Frecuentes)</h2>
            <h2 class="title1">¿Cómo puedo reportar un error?</h2>
            <p class="text-base">Consulta la sección de <a data-scroll="errores-conocidos" href="#" class="no-underline link-color"><b>errores conocidos</b></a> y el resto de esta página. Si no encuentras tu problema, puedes contactarme directamente en Discord (Artur16211).</p>
            <br />
            <h2 class="title1">¿La traducción es compatible con los DLC?</h2>
            <p class="text-base">Sí, la traducción es compatible con todos los DLC del juego.</p>
            <br />
            <h2 class="title1">¿La traducción es compatible con la versión Europea/Japonesa del juego?</h2>
            <p class="text-base">No, de momento la traducción solo es compatible con la versión USA del juego.</p>
            <br />
            <h2 class="title1">El parcheador xdelta dice que mi ROM no es correcta.</h2>
            <p class="text-base">Esto ocurre cuando la ROM (.cia) extraída de tu cartucho tiene un checksum diferente al esperado, el archivo .cia debería tener un <b>MD5</b> <code class="break-words">F80799B298DC69F32863DFC20BE9346D</code>. Aunque no debería suceder, puedes intentar parchear la ROM desactivando la verificación de checksum en tu programa de parcheo (no se garantiza que funcione).</p>
            <br />
            <h2 class="title1">¿La fuente con las texturas no está en HD?</h2>
            <p class="text-base">La fuente del juego no puede ser escalada, por lo que no se puede mejorar su calidad.</p>
            <br />
            <h2 class="title1">¿La traducción es compatible con Mods?</h2>
            <p class="text-base">Sí, la traducción es compatible con otros mods, pero no se garantiza que el contenido de esos mods esté traducido.</p>
            <p class="text-base">Puedes conseguir una versión <b>Mod Compendium</b> de la traducción <a href="https://gamebanana.com/mods/579515" target="_blank" class="no-underline link-color">aquí</a>.</p>
            <br />
            <h2 class="title1">¿La traducción es compatible con Android?</h2>
            <p class="text-base">Sí, la traducción es compatible con Android, pero necesitarás un emulador de 3DS en tu dispositivo y seguir las instrucciones de instalación en esta página.</p>
            <br />
            <h2 class="title1">¿Las texturas HD son compatibles con Android?</h2>
            <p class="text-base">Sí, las texturas HD son compatibles con Android, puedes seguir las instrucciones de instalación en extras con la <b>opción 2</b>.</p>
            <br />
            <h2 class="title1">El juego sigue funcionando pero no avanza después de un diálogo.</h2>
            <p class="text-base">Esto ocurre en algunos emuladores al tener activado el "Modo New 3DS" en la configuración del emulador, desactiva esta opción para solucionar el problema.</p>
            <hr />
            <h2 class="title3 break-words" id="errores-conocidos">Errores Conocidos</h2>
            <ul class="ml-6 list-disc">
              <li>
                <h2 class="title1">Algunos nombres de objetos, Personas y/o habilidades tienen caracteres extraños.</h2>
                <p class="text-base">Esto se debe a un error de memoria del juego, no afecta la jugabilidad y ocurre de manera arbitraria, se soluciona con el tiempo jugando y/o reiniciando el juego.</p>
              </li>
              <li>
                <h2 class="title1">El ataque de Unión de Haru y Yukiko no está traducido.</h2>
                <p class="text-base">De momento, no es posible traducirlo.</p>
              </li>
            </ul>
          </section>
        </div>

        <p class="javascript-disabled hidden">JavaScript está deshabilitado en tu navegador.<br /><br />Por favor, habilítalo para visualizar el contenido de la guía.</p>
      </div>
    </div>

    <div class="hidden w-full px-3 text-center max-[1200px]:!hidden min-[992px]:w-1/6 min-[1201px]:block">
      <div class="creator-panel mt-2 rounded-[15px] bg_container p-2">
        <h2 class="title2 mb-2 text-2xl">Creado Por:</h2>
        {creadores.map((c, i) => (
          <>
            {i > 0 && <hr />}
            <div class="creator-entry mt-4">
              <img src={c.img} alt={c.alt} class="img-fluid pq2-creator-avatar mx-auto" width="128" height="128" loading="lazy" decoding="async" />
              <p class="mt-2 text-xl">{c.name}</p>
              <button class="btn btn-link my-1" type="button" data-collapse-target={`#${c.id}`} aria-label="Mostrar redes sociales">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6l-6-6z" /></svg>
              </button>
              <div class="creator-socials collapsible" id={c.id}>
                {c.socials.map((s) => (
                  s.yt ? (
                    <a href={s.href} target="_blank" class="creator-social-link text-base no-underline link-color">
                      <span class="iconify hide-small" data-icon={s.icon} data-width="24"></span>
                      <span>{s.label}</span>
                    </a>
                  ) : (
                    <span class="creator-social-link">
                      <span class="iconify" data-icon={s.icon} data-width="24"></span>
                      <span>{s.label}</span>
                    </span>
                  )
                ))}
              </div>
            </div>
          </>
        ))}
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-[1140px] px-3">
    <div class="credits-container mx-auto mt-4 rounded-[15px] bg_container p-6">
      <h3 class="break-words text-center"><b>Agradecimientos Especiales</b></h3>
      <p class="text-center">Agradecemos a las siguientes personas y proyectos por su ayuda directa o indirecta en esta traducción:</p>
      <ul class="grid grid-cols-1 gap-x-6 break-words md:grid-cols-2">
        {creditos.map((c) => (
          <li>
            <strong>{c.name}:</strong>{' '}
            <a href={c.href} target="_blank" class="no-underline link-color">{c.text}</a>
            {c.extra && (<>, <a href={c.extra.href} target="_blank" class="no-underline link-color">{c.extra.text}</a></>)}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <MobileDrawer
    id="pq2-credits"
    label="Creado Por"
    breakpoint={1200}
    panelWidth="min(260px, 86vw)"
    panelClass="pq2-drawer"
    triggerClass="pq2-drawer-trigger animated-border"
    triggerLabel="Abrir Creado Por"
  >
    <img slot="trigger" src="/pq2/img/creadopor_card.webp" alt="" width="110" height="72" aria-hidden="true" loading="lazy" decoding="async" />

    <h2 class="title2 mb-2 text-2xl">Creado Por:</h2>
    {creadores.map((c) => (
      <div class="pq2-creator mt-5">
        <img data-drawer-src={c.img} alt={c.alt} class="img-fluid pq2-creator-avatar mx-auto" width="128" height="128" loading="lazy" decoding="async" />
        <p class="creator-name mt-2 text-xl">{c.name}</p>
        <div class="pq2-socials">
          {c.socials.map((s) => (
            s.href ? (
              <a href={s.href} target="_blank" class="pq2-social no-underline link-color">
                <span class="iconify" data-icon={s.icon} data-width="22"></span>
                <span>{s.label}</span>
              </a>
            ) : (
              <span class="pq2-social">
                <span class="iconify" data-icon={s.icon} data-width="22"></span>
                <span>{s.label}</span>
              </span>
            )
          ))}
        </div>
      </div>
    ))}
  </MobileDrawer>

  <footer class="footer mt-4">
    <div class="mx-auto max-w-[1140px] px-3">
      <div class="mt-6 mb-12 flex flex-col items-center gap-4 md:flex-row md:justify-between">
        <a class="logo-link" href="/">
          <img src="/pq2/img/a2logo/logo_outline.webp" alt="Logo" class="a2logofooter" width="6989" height="2955" loading="lazy" decoding="async" style="width: 200px; height: auto;" />
        </a>
        <p class="max-w-md text-center text-white">Este proyecto no está afiliado con ATLUS o SEGA. Todos los derechos reservados por sus respectivos propietarios.</p>
      </div>
    </div>
  </footer>

  <script is:inline src="/pagejs/descargar.js"></script>
</BaseLayout>
