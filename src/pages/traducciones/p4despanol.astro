---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const comparators = [
  { before: 'menu_ps4', after: 'menu_psv' },
  { before: 'custom_ps4_2', after: 'custom_psv_2' },
  { before: 'stage_ps4', after: 'stage_psv' },
  { before: 'collection_ps4', after: 'collection_psv' },
  { before: 'event_ps4', after: 'event_psv' },
  { before: 'shop_ps4', after: 'shop_psv' },
];
const desktopSlides = [
  comparators.slice(0, 2),
  comparators.slice(2, 4),
  comparators.slice(4, 6),
];
---

<BaseLayout
  title="Persona 4 Dancing - Traducción al Español"
  description="A2 Workshop - Persona 4 Dancing en Español"
  canonical="https://a2workshop.github.io/traducciones/p4despanol"
  ogTitle="A2Workshop"
  ogImage="https://a2workshop.github.io/p4d/img/es_logo/webpreview.webp"
  themeColor="#ff33ffa8"
  bodyStyle="color:#000;"
>
  <link slot="head" rel="stylesheet" href="/p4d/style.css" />

  <Navbar activeKey="default" boldProyecto boldContacto />

  <div class="video-wrapper">
    <iframe
      src="https://www.youtube.com/embed/AENzjfi1S0Q?rel=0&autoplay=1&mute=1&loop=1&playlist=AENzjfi1S0Q&controls=0&modestbranding=1&fs=0&disablekb=1&iv_load_policy=3"
      frameborder="0" allow="autoplay; fullscreen" allowfullscreen title="fondo"></iframe>
    <div class="pattern-overlay"></div>
    <div class="logo-container text-center">
      <img src="/p4d/img/es_logo/es_logo.webp" alt="Logo" class="logo_p4d w-full" decoding="async" fetchpriority="high" />
      <a class="text-white text-white-outline no-underline"><b>PRÓXIMAMENTE</b></a><br />
      <a href="#" class="btn-primary mt-2 inline-block opacity-50 pointer-events-none">Descargar</a>
    </div>
  </div>

  <div class="scroll-down-arrow" id="scrollDownArrow" aria-label="Bajar">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" /></svg>
  </div>

  <section class="section1">
    <div class="mx-[10%] text-center">
      <h1 class="text-bg">Persona 4 Dancing Traducción al Español</h1>
      <h2 class="text-white text-white-outline title-screenshots text-3xl font-bold"><b>Capturas</b></h2>

      <div class="p4d-carousel p4d-carousel-desktop" id="p4d-gallery" data-carousel>
        {desktopSlides.map((slide, slideIndex) => (
          <div class={`p4d-slide${slideIndex === 0 ? ' active' : ''}`}>
            <div class="p4d-slide-grid">
              {slide.map((c) => (
                <div class="image-comparator">
                  <div class="comparator-labels">
                    <span class="label-left">PS4</span>
                    <span class="label-right">PS Vita</span>
                  </div>
                  <div class="image-container">
                    <img src={`/p4d/img/screenshots/${c.before}.webp`} class="image-before" alt="PS4" loading="lazy" decoding="async" />
                    <img src={`/p4d/img/screenshots/${c.after}.webp`} class="image-after" alt="PS Vita" loading="lazy" decoding="async" />
                  </div>
                  <div class="slider"></div>
                </div>
              ))}
            </div>
          </div>
        ))}
        <button class="p4d-control p4d-control-prev" type="button" data-carousel-prev aria-label="Anterior"><span></span></button>
        <button class="p4d-control p4d-control-next" type="button" data-carousel-next aria-label="Siguiente"><span></span></button>
      </div>

      <div class="p4d-carousel p4d-carousel-mobile" data-carousel>
        {comparators.map((c, slideIndex) => (
          <div class={`p4d-slide${slideIndex === 0 ? ' active' : ''}`}>
            <div class="image-comparator">
              <div class="comparator-labels">
                <span class="label-left">PS4</span>
                <span class="label-right">PS Vita</span>
              </div>
              <div class="image-container">
                <img src={`/p4d/img/screenshots/${c.before}.webp`} class="image-before" alt="PS4" loading="lazy" decoding="async" />
                <img src={`/p4d/img/screenshots/${c.after}.webp`} class="image-after" alt="PS Vita" loading="lazy" decoding="async" />
              </div>
              <div class="slider"></div>
            </div>
          </div>
        ))}
        <button class="p4d-control p4d-control-prev" type="button" data-carousel-prev aria-label="Anterior"><span></span></button>
        <button class="p4d-control p4d-control-next" type="button" data-carousel-next aria-label="Siguiente"><span></span></button>
      </div>
    </div>
  </section>

  <dialog id="imageModal" class="p4d-modal">
    <button id="modalClose" class="p4d-modal-close" aria-label="Cerrar">&times;</button>
    <button id="prevImage" class="p4d-modal-arrow p4d-modal-prev" aria-label="Anterior">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.4 5.4 8.8 12l6.6 6.6-1.8 1.8L5.2 12l8.4-8.4z" /></svg>
    </button>
    <img id="modalImage" alt="captura ampliada" decoding="async" />
    <div id="imageLabel" style="display:none;"></div>
    <button id="nextImage" class="p4d-modal-arrow p4d-modal-next" aria-label="Siguiente">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8.6 18.6 6.6-6.6-6.6-6.6 1.8-1.8 8.4 8.4-8.4 8.4z" /></svg>
    </button>
  </dialog>

  <footer class="p4d-footer">
    <div class="p4d-footer-grid">
      <a href="/"><img src="/assets/img/A2/logo.webp" alt="Logo" class="a2logofooter" loading="lazy" decoding="async" /></a>
      <div></div>
      <p class="copyright-text">Este proyecto no est&aacute; afiliado con ATLUS o SEGA. Todos los derechos reservados por sus respectivos propietarios.</p>
    </div>
  </footer>

  <script>
    import '../../scripts/p4d-page.ts';
  </script>

  <style>
    .p4d-carousel {
      position: relative;
      padding: 20px 0;
    }
    .p4d-slide {
      display: none;
    }
    .p4d-slide.active {
      display: block;
    }
    .p4d-slide-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.5rem;
      max-width: 1320px;
      margin: 0 auto;
    }
    .p4d-carousel-mobile {
      display: none;
    }
    .p4d-control {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 15%;
      border: 0;
      background: transparent;
      cursor: pointer;
      z-index: 3;
    }
    .p4d-control-prev {
      left: 0;
    }
    .p4d-control-next {
      right: 0;
    }
    .p4d-control span {
      display: inline-block;
      width: 2rem;
      height: 2rem;
      border-radius: 80%;
      background-color: #ff33ffa8;
      box-shadow: 0 0 5px #ff33ff;
      position: relative;
    }
    .p4d-control span::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 0.7rem;
      height: 0.7rem;
      border-top: 3px solid #fff;
      border-left: 3px solid #fff;
    }
    .p4d-control-prev span::before {
      transform: translate(-35%, -50%) rotate(-45deg);
    }
    .p4d-control-next span::before {
      transform: translate(-65%, -50%) rotate(135deg);
    }
    @media (max-width: 1200px) {
      .p4d-carousel-desktop {
        display: none;
      }
      .p4d-carousel-mobile {
        display: block;
      }
    }
    .p4d-modal {
      width: 100vw;
      max-width: 100vw;
      height: 100vh;
      max-height: 100vh;
      border: none;
      padding: 0;
      background: #000000b9;
    }
    .p4d-modal::backdrop { background: rgba(0, 0, 0, 0.8); }
    .p4d-modal img {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      max-height: 80vh;
      max-width: 92vw;
      object-fit: contain;
    }
    #imageLabel {
      position: absolute;
      bottom: 8%;
      left: 50%;
      transform: translateX(-50%);
    }
    .p4d-modal-close,
    .p4d-modal-arrow {
      position: absolute;
      background: #ff33ff;
      border: none;
      color: #fff;
      cursor: pointer;
      z-index: 2;
      box-shadow: 0 0 5px #ff33ff;
    }
    .p4d-modal-close {
      top: 1rem;
      right: 1.5rem;
      width: 2rem;
      height: 2rem;
      border-radius: 2px;
      font-size: 1.25rem;
      line-height: 1;
    }
    .p4d-modal-arrow {
      top: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      padding: 0;
      border-radius: 50%;
      transform: translateY(-50%);
      font-size: 2rem;
      line-height: 1;
    }
    .p4d-modal-arrow svg {
      display: block;
      width: 26px;
      height: 26px;
      fill: currentColor;
    }
    .p4d-modal-prev { left: 1rem; }
    .p4d-modal-next { right: 1rem; }
    .p4d-footer {
      margin-top: 3rem;
      padding: 3rem 1rem 2rem;
      font-family: 'motiva';
    }
    .p4d-footer-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: min(100% - 24px, 1320px);
      margin: 0 auto;
      align-items: start;
    }
    .p4d-footer .a2logofooter {
      width: 200px;
      max-width: 60%;
      height: auto;
    }
    .p4d-footer p {
      margin: 0;
      color: #fff;
      text-align: center;
    }
    @media (max-width: 990px) {
      .p4d-footer-grid {
        display: block;
        text-align: center;
      }
      .p4d-footer p {
        max-width: 520px;
        margin: 1rem auto 0;
      }
    }
  </style>
</BaseLayout>

